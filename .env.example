# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/indlish?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_APP_NAME="indlish"

# MSG91 Email (https://msg91.com)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_EMAIL="notifications@indlish.com"
# Template IDs for template-based emails (optional, used by src/lib/msg91.ts)
MSG91_TEMPLATE_WELCOME="your-welcome-template-id"
MSG91_TEMPLATE_PASSWORD_RESET="your-password-reset-template-id"